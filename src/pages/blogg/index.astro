---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import type { WordPressPost } from "../../interfaces/models";
const allBlogPosts = await fetch(
  "http://helenaswane-wordpress.local/wp-json/wp/v2/posts?_embed",
);
const posts = await allBlogPosts.json();
---

<BaseLayout title="Helena Swane - Blogg" description="">
  <section id="blogPostGallery" class="blog-post-gallery">
    <div class="blog-hero">
      <h2 class="blog-post-gallery-title">Blogg</h2>
      <p>- Lorem ipsum delore</p>
    </div>
    <div class="blog-post-grid">
      {
        posts.map((post: WordPressPost) => {
          const image = post._embedded?.["wp:featuredmedia"]?.[0]?.source_url;

          if (!image) return null;

          return (
            <BlogPost
              title={post.title.rendered}
              image={image}
              url={`/blogg/${post.slug}`}
              bio={post.content.rendered}
            />
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100vw;
    height: 300px;
    background-image: url("/blog-hero.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    padding-left: 130px;
    margin-top: 30px;
    margin-bottom: 50px;
  }

  .blog-hero::before {
    content: "";
    position: absolute;
    left: 110px;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 150px;
    background-color: white;
  }

  .blog-post-gallery {
    background-color: #faf6f1;
    width: 100vw;
    padding-bottom: 70px;
  }

  .blog-post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 60px;
    row-gap: 22px;
    margin: 20px 0;
    overflow: hidden;
    padding-inline: 100px;

    @media (max-width: 1400px) {
      grid-template-columns: repeat(2, 1fr);
      width: 830px;
      padding-inline: 0;
      margin-inline: auto;
    }

    @media (max-width: 950px) {
      grid-template-columns: repeat(1, 1fr);
      width: 350px;
    }
  }

  .blog-post-gallery-title {
    color: white;
    font-size: 43px;
    font-family: "Raleway", sans-serif;
    margin-bottom: 0;
    font-size: 3rem;

    @media (max-width: 1400px) {
      width: 830px;
      margin-inline: auto;
      text-align: left;
      padding-inline: 0;
    }

    @media (max-width: 950px) {
      width: 100%;
      max-width: 350px;
    }
  }

  .blog-hero h2,
  .blog-hero p {
    color: white;
    margin: 0;
    padding-left: 10px;
  }
</style>
